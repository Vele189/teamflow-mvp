{
    "name": "continuum-monorepo",
    "version": "1.0.0",
    "private": true,
    "main": "index.js",
    "scripts": {
        "start:frontend": "npm run start --workspace=@continuum-monorepo/frontend",
        "start:backend": "npm run start --workspace=@continuum-monorepo/backend",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write .",
        "format:check": "prettier . --check .",
        "test": "npm run test --workspaces --if-present",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "workspaces": [
        "apps/frontend",
        "apps/backend",
        "packages/shared"
    ],
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.9.5"
    }
}
